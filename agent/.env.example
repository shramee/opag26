# ─── AXL node URLs ────────────────────────────────────────────────────────────
# Broker connects to its AXL node; LP connects to its own.
AXL_BASE_URL=http://127.0.0.1:9002       # broker (or LP: use 9003 for local dev)

# ─── 0G Storage ───────────────────────────────────────────────────────────────
ZERO_G_PRIVATE_KEY=0x_your_private_key_here
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ─── 0G Compute ───────────────────────────────────────────────────────────────
# Find a provider address via: node zero_g/list-providers.mjs
ZERO_G_PROVIDER_ADDRESS=0x_provider_address_here

# ─── LP Agent settings ────────────────────────────────────────────────────────
LP_AGENT_ID=lp-agent-1
LP_MIN_SPREAD=0.001          # minimum spread fraction (0.001 = 0.1%)
POLL_INTERVAL_SECS=0.5

# ─── Broker Agent settings ────────────────────────────────────────────────────
LP_PEERS_FILE=lp-peers.json  # path to file listing LP AXL peer IDs
QUOTE_TIMEOUT_SECS=15        # wait this long for LP quotes
CONFIRM_TIMEOUT_SECS=30      # wait this long for LP confirmation

# ─── MIST Escrow (KeeperHub integration) ──────────────────────────────────────
MIST_ESCROW_ADDRESS=0x_mist_escrow_contract_address
