{
	"name": "@opag26/sdk",
	"version": "0.1.0",
	"description": "Reusable TypeScript SDK utilities for Node.js, browser, and React applications.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"dev": "tsup src/index.ts --format esm,cjs --dts --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"sync-env": "node scripts/sync-env.mjs"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"viem": "^2.48.8",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@mistcash/sdk": "^0.5.2"
	}
}