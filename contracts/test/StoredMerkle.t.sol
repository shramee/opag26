pragma solidity ^0.8.20;

import { Test } from "forge-std/Test.sol";
import { StoredMerkle } from "../src/StoredMerkle.sol";

contract StoredMerkleWrapper is StoredMerkle {
	function appendPublic(uint256 leaf) external returns (uint256) {
		return append(leaf);
	}
}

contract StoredMerkleTest is Test {
	StoredMerkleWrapper tree;

	function setUp() public {
		tree = new StoredMerkleWrapper();
	}

	// ========== Sequential append with expected roots ==========

	function test_append_roots_sequential() public {
		uint256[17] memory txHashes = [
			21800788720243668211022282954415640828877619902704988492737012276854066445696,
			3085369792021572813874189029251258180794990255961832494828775994922158036234,
			19557596820999716049296686498878519747409337373224915747237288517573466629395,
			6172886096280718341334720106191253083912371110418380072288769890582653857688,
			5045913109236175732141492779627732902380251183916448926489398776066409517431,
			14775213759703353414310927471857727352121286866791198321075530325785016656724,
			9536463380437401254764466741974414760608069769758680425094770891216155694823,
			2329959639148705799849666797934792542729560664605593774505199618533325071259,
			17973834992384167016953274666683044877308283647676521507542396051606562404496,
			12912012348367650055893387098114481013151042050164037669427239172555750202200,
			1008026554098851878422342533794385012679739410937036712676996668239463491231,
			1861330214235939829261608669387176256529862331560066193887209211494543136023,
			4211183826732505466207893889743950651144695533754369269070511235935814457089,
			20027053073158469956371380766224640643041689760683727285787697683368656029684,
			12144268283234630651983041382449379887964168207507875312605612472053950545451,
			20257791238557151844025924914429099101995076880244363487202705570149386454429,
			15958014877289584230250129466098873891600500953697260939062827907841210944178
		];

		uint256[17] memory expectedRoots = [
			21800788720243668211022282954415640828877619902704988492737012276854066445696,
			8072968958275108028436000247321928586753756911742686996872432251800120535805,
			841713486886538253523295176149743432279260645898056898832258405176436094652,
			4497115503911053484657860142299271014526421215379930133650240897725514032068,
			8134659598460662209084314264648381776900745718459073306254728314458040685679,
			18780803740534951225161543707463775229681065856253994095524113461869726018297,
			5138522003857908698625010213557664112737788728909730414546272832036260638789,
			8194804456177415092128957810606291818286017422712625647737787629281658493684,
			13159292404933987957028979986572854235181531640501395080297082902419437513817,
			6499405501107643367461855389772605496887052716325758556339302672462981423498,
			15308794898682831849281047250406562820386589709878589233312950499708197814043,
			7503558440310213557250907303113484144490604355933763052812075836090015712466,
			12409148246509362113171049166567035164660722685506557793924785126993653185025,
			4992841070140901734059992191515537482379972297785149897903712766496779676038,
			5858366357969271519860325057475406830818385175726602861790518847169351016776,
			1777131791414798356243928467935142433257104873928639333387827389280267588205,
			3763585553850047511707113623502126536790765865212457401143583307870173564545
		];

		for (uint256 i = 0; i < txHashes.length; i++) {
			uint256 root = tree.appendPublic(txHashes[i]);
			assertEq(root, expectedRoots[i], _errMsg(i));
			assertEq(tree.getRoot(), expectedRoots[i], _errMsg(i));
		}
	}

	// ========== Individual append tests ==========

	function test_append_first_leaf_is_own_root() public {
		uint256 leaf = 21800788720243668211022282954415640828877619902704988492737012276854066445696;
		uint256 root = tree.appendPublic(leaf);
		assertEq(root, leaf);
	}

	function test_append_second_leaf() public {
		tree.appendPublic(
			21800788720243668211022282954415640828877619902704988492737012276854066445696
		);
		uint256 root = tree.appendPublic(
			3085369792021572813874189029251258180794990255961832494828775994922158036234
		);
		assertEq(
			root,
			8072968958275108028436000247321928586753756911742686996872432251800120535805
		);
	}

	function test_append_height_grows() public {
		assertEq(tree.height(), 0);
		tree.appendPublic(1);
		assertEq(tree.height(), 0); // single node, height 0
		tree.appendPublic(2);
		assertEq(tree.height(), 1); // pair hashed, height 1
		tree.appendPublic(3);
		assertEq(tree.height(), 2); // 3rd leaf forces a new level
		tree.appendPublic(4);
		assertEq(tree.height(), 2); // 4th completes the level, no new level needed
	}

	function test_get_root_matches_append_return() public {
		for (uint256 i = 0; i < 5; i++) {
			uint256 returned = tree.appendPublic(uint256(keccak256(abi.encode(i))));
			assertEq(tree.getRoot(), returned);
		}
	}

	// ========== Proof tests ==========

	function test_compute_and_verify_proof_after_appends() public {
		uint256[17] memory txHashes = [
			21800788720243668211022282954415640828877619902704988492737012276854066445696,
			3085369792021572813874189029251258180794990255961832494828775994922158036234,
			19557596820999716049296686498878519747409337373224915747237288517573466629395,
			6172886096280718341334720106191253083912371110418380072288769890582653857688,
			5045913109236175732141492779627732902380251183916448926489398776066409517431,
			14775213759703353414310927471857727352121286866791198321075530325785016656724,
			9536463380437401254764466741974414760608069769758680425094770891216155694823,
			2329959639148705799849666797934792542729560664605593774505199618533325071259,
			17973834992384167016953274666683044877308283647676521507542396051606562404496,
			12912012348367650055893387098114481013151042050164037669427239172555750202200,
			1008026554098851878422342533794385012679739410937036712676996668239463491231,
			1861330214235939829261608669387176256529862331560066193887209211494543136023,
			4211183826732505466207893889743950651144695533754369269070511235935814457089,
			20027053073158469956371380766224640643041689760683727285787697683368656029684,
			12144268283234630651983041382449379887964168207507875312605612472053950545451,
			20257791238557151844025924914429099101995076880244363487202705570149386454429,
			15958014877289584230250129466098873891600500953697260939062827907841210944178
		];

		for (uint256 i = 0; i < txHashes.length; i++) {
			tree.appendPublic(txHashes[i]);
		}

		uint256 finalRoot = tree.getRoot();

		// Verify proof for each leaf
		for (uint256 i = 0; i < txHashes.length; i++) {
			uint256[] memory proof = tree.computeProof(i);
			assertTrue(
				tree.verifyProof(finalRoot, txHashes[i], proof),
				string(abi.encodePacked("proof invalid for leaf ", vm.toString(i)))
			);
		}
	}

	function test_compute_root_from_proof_matches_stored_root() public {
		tree.appendPublic(
			21800788720243668211022282954415640828877619902704988492737012276854066445696
		);
		tree.appendPublic(
			3085369792021572813874189029251258180794990255961832494828775994922158036234
		);
		tree.appendPublic(
			19557596820999716049296686498878519747409337373224915747237288517573466629395
		);

		uint256 root = tree.getRoot();
		uint256[] memory proof = tree.computeProof(0);
		uint256 computed = tree.computeRoot(
			21800788720243668211022282954415640828877619902704988492737012276854066445696,
			proof
		);
		assertEq(computed, root);
	}

	// ========== initStorage tests ==========

	function test_init_storage_single_leaf() public {
		uint256[] memory leaves = new uint256[](1);
		leaves[0] = 42;
		tree.initStorage(leaves);
		assertEq(tree.getRoot(), 42);
		assertEq(tree.height(), 0);
	}

	function test_init_storage_two_leaves() public {
		uint256[] memory leaves = new uint256[](2);
		leaves[
			0
		] = 21800788720243668211022282954415640828877619902704988492737012276854066445696;
		leaves[
			1
		] = 3085369792021572813874189029251258180794990255961832494828775994922158036234;
		tree.initStorage(leaves);
		assertEq(
			tree.getRoot(),
			8072968958275108028436000247321928586753756911742686996872432251800120535805
		);
		assertEq(tree.height(), 1);
	}

	function test_init_storage_odd_leaves_pads_with_zero() public {
		uint256[] memory leaves = new uint256[](3);
		leaves[0] = 1;
		leaves[1] = 2;
		leaves[2] = 3;
		tree.initStorage(leaves);
		// Should not revert — 3 leaves gets padded to 4 (last = 0)
		assertEq(tree.height(), 2);
		assertEq(tree.lenAtHeight(0), 3);
	}

	// ========== lenAtHeight / readLeavesAtHeight ==========

	function test_len_at_height_updates_on_append() public {
		tree.appendPublic(1);
		assertEq(tree.lenAtHeight(0), 1);
		tree.appendPublic(2);
		assertEq(tree.lenAtHeight(0), 2);
		assertEq(tree.lenAtHeight(1), 1);
	}

	function test_read_leaves_at_height_zero() public {
		tree.appendPublic(10);
		tree.appendPublic(20);
		uint256[] memory leaves = tree.readLeavesAtHeight(0);
		assertEq(leaves.length, 2);
		assertEq(leaves[0], 10);
		assertEq(leaves[1], 20);
	}

	// ========== helpers ==========

	function _errMsg(uint256 i) internal pure returns (string memory) {
		return
			string(abi.encodePacked("wrong root after append #", vm.toString(i + 1)));
	}
}
