# ============================================================
# Chamber — 0G Testnet Deployment Environment
# Copy to .env and fill in your values before running deploy.sh
# ============================================================

# Deployer private key (hex, no 0x prefix)
PRIVATE_KEY=your_private_key_here

# 0G Newton Testnet RPC endpoint
# Public endpoint: https://evmrpc-testnet.0g.ai
OG_TESTNET_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G block explorer base URL (used by forge for --verify)
OG_EXPLORER_URL=https://chainscan-newton.0g.ai/api

# API key for the 0G explorer (set to any non-empty string if not required)
OG_ETHERSCAN_API_KEY=any

# Set to false to skip deploying the DummyERC20 test token
DEPLOY_DUMMY_ERC20=true
