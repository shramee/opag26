# --- Wallet & RPC ---
PRIVATE_KEY=0xacac...                          # Bob's private key (also used as MIST master key)
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# --- Contract addresses (deployed Chamber + Escrow) ---
CHAMBER_ADDRESS=0xddD554D84621C618fEc4C73760456Eb2DAe25444
ESCROW_ADDRESS=0x3956B329Dbbf7248b2c830Ba2D588E4cC0305E85

# --- Tokens (symbol:address pairs, comma separated) ---
TOKENS=dumETH:0xf137b3dBBcd416898a2bfeBf5c19a3cD64Bf0D90,dumUSD:0xe8abb36B517f8fA93d08a07f79F57A29B9F117e0

# --- Peer ---
PEER_URL=http://127.0.0.1:3101                  # Jill's HTTP endpoint
PORT=3100                                       # Bob's HTTP endpoint

# --- LLM ---
INFERENCE_API_KEY=sk-...
MODEL=zai-org/GLM-5-FP8
MAX_STEPS=12
VERBOSE=true

# --- Optional 0g kv persistence for MIST state ---
# ZERO_G_PRIVATE_KEY=0x...                        # defaults to PRIVATE_KEY
# ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
# ZERO_G_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
# ZERO_G_KV_RPC_URL=http://127.0.0.1:6789
# ZERO_G_FLOW_ADDRESS=0x...
# ZERO_G_STREAM_ID=0x...                          # defaults to a derived per-agent stream id
